#!/usr/bin/env node
"use strict";

/*
  Hardened single-file KEM-DEM processor (secp256k1 ECDH + ChaCha20-Poly1305).
  - Real asymmetric confidentiality on Bitcoin's curve
  - Outputs encryption package for commitment/timestamping
  - Round-trip verification
  - Adds: strict UTF-8 STDIN validation + word-wrapped output
*/

import crypto from "crypto";
import { TextDecoder } from "util";

/* ============================================================
   CLI (wrap + limits)
============================================================ */
function parseArgs(argv) {
  const out = {
    wrap: null,                // number | null (auto)
    maxBytes: 5 * 1024 * 1024, // 5 MiB default
    allowEmpty: false,
  };
  for (let i = 2; i < argv.length; i++) {
    const a = argv[i];
    if (a === "--wrap") {
      const v = argv[++i];
      if (!v || !/^\d+$/.test(v)) throw new Error("Invalid --wrap value (expected integer).");
      out.wrap = Math.max(20, Math.min(400, parseInt(v, 10)));
    } else if (a === "--max-bytes") {
      const v = argv[++i];
      if (!v || !/^\d+$/.test(v)) throw new Error("Invalid --max-bytes value (expected integer).");
      out.maxBytes = Math.max(1, parseInt(v, 10));
    } else if (a === "--allow-empty") {
      out.allowEmpty = true;
    } else if (a === "--help" || a === "-h") {
      console.log(`Usage:
  cat file.txt | node kem_dem.js [--wrap N] [--max-bytes N] [--allow-empty]

Options:
  --wrap N       Wrap output to N columns (default: terminal width or 80)
  --max-bytes N  Max stdin bytes accepted (default: 5242880)
  --allow-empty  Allow empty stdin without error (otherwise falls back to TEST_DATA only if TTY)
`);
      process.exit(0);
    } else {
      throw new Error(`Unknown arg: ${a}`);
    }
  }
  return out;
}

const ARGS = parseArgs(process.argv);

