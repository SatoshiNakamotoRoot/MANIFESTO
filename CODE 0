#!/usr/bin/env node
"use strict";

import crypto from "crypto";
import { TextDecoder } from "util";

/* ============================================================
   CLI
============================================================ */
function parseArgs(argv) {
  const out = {
    wrap: null,
    maxBytes: 5 * 1024 * 1024,
    allowEmpty: false,

    timeIso: null,
    timeUnix: null,

    jsonOnly: true, // emit single JSON record by default
    sphincsModule: null,     // e.g. "@noble/post-quantum/sphincs+sha2-128f"
    sphincsSkHex: null,      // secret key hex
    sphincsCtx: "RAT-ATTEST-v1", // context string domain-sep
  };

  for (let i = 2; i < argv.length; i++) {
    const a = argv[i];
    if (a === "--wrap") out.wrap = clampInt(argv[++i], 20, 400, "--wrap");
    else if (a === "--max-bytes") out.maxBytes = clampInt(argv[++i], 1, 1e9, "--max-bytes");
    else if (a === "--allow-empty") out.allowEmpty = true;
    else if (a === "--time-iso") out.timeIso = argv[++i];
    else if (a === "--time-unix") out.timeUnix = clampInt(argv[++i], 0, 2 ** 53 - 1, "--time-unix");
    else if (a === "--text") out.jsonOnly = false;
    else if (a === "--json") out.jsonOnly = true;
    else if (a === "--sphincs-module") out.sphincsModule = argv[++i];
    else if (a === "--sphincs-sk-hex") out.sphincsSkHex = argv[++i];
    else if (a === "--sphincs-ctx") out.sphincsCtx = argv[++i];
    else if (a === "--help" || a === "-h") {
      console.log(`Usage:
  cat input.txt | node kem_dem_attest.js [--json|--text] [--wrap N]
      [--time-iso ISO] [--time-unix SECONDS]
      [--sphincs-module MODULE] [--sphincs-sk-hex HEX] [--sphincs-ctx STR]

Defaults:
  --json (single attestation record only)

Notes:
  - SPHINCS signing requires an external module/library (dynamic import).
  - OP_RETURN payload is 36 bytes: "RAT0" + 32-byte attestation_hash.
`);
      process.exit(0);
    } else {
      throw new Error(`Unknown arg: ${a}`);
    }
  }
  return out;
}
function clampInt(v, lo, hi, flag) {
  if (!v || !/^\d+$/.test(String(v))) throw new Error(`Invalid ${flag} value.`);
  const n = parseInt(v, 10);
  if (n < lo || n > hi) throw new Error(`${flag} out of range.`);
  return n;
}
const ARGS = parseArgs(process.argv);

/* ============================================================
   Test fallback (only used if TTY)
============================================================ */
const TEST_DATA = `ᘛ⁠⁐̤⁠ᘀ00∞ ❤️

transmission: PGHIJLL`;

/* ============================================================
   Helpers
============================================================ */
function sha256(d){ return crypto.createHash("sha256").update(d).digest(); }
function sha256Hex(d){ return sha256(d).toString("hex"); }
function dsha256(d){ return sha256(sha256(d)); }
function hmacSha256(k,d){ return crypto.createHmac("sha256",k).update(d).digest(); }
function hkdf(ikm,salt,info,len){
  const prk = hmacSha256(salt, ikm);
  let t = Buffer.alloc(0), okm = Buffer.alloc(0), c = 1;
  while (okm.length < len) {
    t = hmacSha256(prk, Buffer.concat([t, info, Buffer.from([c++])]));
    okm = Buffer.concat([okm, t]);
  }
  return okm.subarray(0, len);
}
function b64u(b){ return b.toString("base64").replace(/\+/g,"-").replace(/\//g,"_").replace(/=+$/,""); }
function b64uDec(s){
  const p = s.replace(/-/g,"+").replace(/_/g,"/") + "===".slice((s.length + 3) % 4);
  return Buffer.from(p, "base64");
}
function hexToBuf(h, label){
  if (typeof h !== "string" || !/^[0-9a-fA-F]*$/.test(h) || (h.length % 2)) {
    throw new Error(`Invalid hex for ${label}`);
  }
  return Buffer.from(h, "hex");
}

/* ============================================================
   Timestamp (deterministic replay supported)
============================================================ */
function generateTimestamp() {
  let date;
  if (ARGS.timeIso) date = new Date(ARGS.timeIso);
  else if (ARGS.timeUnix != null) date = new Date(ARGS.timeUnix * 1000);
  else date = new Date();

  if (isNaN(date.getTime())) throw new Error("Invalid timestamp");

  const iso = date.toISOString();
  const unix = Math.floor(date.getTime() / 1000);
  const millis = date.getTime();
  const hr = process.hrtime.bigint().toString(); // informative; not used for deterministic hashes unless you want it

  // Canonical timestamp record used for hashing/signing
  const canonicalObj = { iso, unix, millis };
  const canonical = JSON.stringify(canonicalObj);

  // Merkle-safe / domain-separated hash of timestamp
  const ts_hash = dsha256(Buffer.concat([
    Buffer.from("TS|RATATTEST|v1|", "utf8"),
    Buffer.from(canonical, "utf8")
  ]));

  return { iso, unix, millis, hr, canonical, ts_hash_hex: ts_hash.toString("hex") };
}

/* ============================================================
   STDIN read + strict UTF-8 validation
============================================================ */
async function readStdinValidated({ maxBytes, allowEmpty }){
  if (process.stdin.isTTY) {
    const b = Buffer.alloc(0);
    return { buf: b, sha256hex: sha256Hex(b) };
  }

  const chunks = [];
  let total = 0;

  return await new Promise((resolve, reject) => {
    process.stdin.on("data", (c) => {
      total += c.length;
      if (total > maxBytes) {
        reject(new Error(`STDIN too large: ${total} bytes (max ${maxBytes}).`));
        process.stdin.pause();
        return;
      }
      chunks.push(c);
    });
    process.stdin.on("error", reject);
    process.stdin.on("end", () => {
      const buf = Buffer.concat(chunks);
      if (!allowEmpty && buf.length === 0) {
        reject(new Error("STDIN is empty (pipe input or use --allow-empty)."));
        return;
      }
      const dec = new TextDecoder("utf-8", { fatal: true });
      try { dec.decode(buf); }
      catch { reject(new Error("STDIN is not valid UTF-8 (fatal decode failed).")); return; }
      resolve({ buf, sha256hex: sha256Hex(buf) });
    });
  });
}

/* ============================================================
   secp256k1 ECDH KEM
============================================================ */
function kemKeygen(){
  const receiver = crypto.createECDH("secp256k1");
  receiver.generateKeys();
  return { pk: receiver.getPublicKey(), sk: receiver.getPrivateKey() };
}
function kemEncaps(pk){
  const sender = crypto.createECDH("secp256k1");
  sender.generateKeys();
  const ctKem = sender.getPublicKey();
  const ss_raw = sender.computeSecret(pk);
  const ss = hkdf(ss_raw, sha256(Buffer.from("SS")), Buffer.from("ss"), 32);
  return { ctKem_b64u: b64u(ctKem), ss };
}
function kemDecaps(sk, ctKem_b64u){
  const ctBytes = b64uDec(ctKem_b64u);
  const receiver = crypto.createECDH("secp256k1");
  receiver.setPrivateKey(sk);
  const ss_raw = receiver.computeSecret(ctBytes);
  return hkdf(ss_raw, sha256(Buffer.from("SS")), Buffer.from("ss"), 32);
}

/* ============================================================
   DEM: ChaCha20-Poly1305
============================================================ */
function demEncrypt(ss, plaintext){
  const key = hkdf(ss, sha256(Buffer.from("DEM")), Buffer.from("KEY"), 32);
  const nonce = crypto.randomBytes(12);
  const cipher = crypto.createCipheriv("chacha20-poly1305", key, nonce, { authTagLength: 16 });
  const ct = Buffer.concat([cipher.update(Buffer.from(plaintext,"utf8")), cipher.final()]);
  const tag = cipher.getAuthTag();
  return { nonce_b64u: b64u(nonce), ct_b64u: b64u(ct), tag_b64u: b64u(tag), ct_raw: ct };
}
function demDecrypt(ss, obj){
  const key = hkdf(ss, sha256(Buffer.from("DEM")), Buffer.from("KEY"), 32);
  const nonce = b64uDec(obj.nonce_b64u);
  const ct = b64uDec(obj.ct_b64u);
  const tag = b64uDec(obj.tag_b64u);
  const dec = crypto.createDecipheriv("chacha20-poly1305", key, nonce, { authTagLength: 16 });
  dec.setAuthTag(tag);
  return Buffer.concat([dec.update(ct), dec.final()]).toString("utf8");
}

/* ============================================================
   Attestation hashing + OP_RETURN
============================================================ */
function domainSeparatedAttestHash({ ts_hash_hex, stdin_sha256_hex, dem_ct_sha256_hex }) {
  // attestation_hash = dSHA256("ATTEST|RAT|v1|" || ts_hash || stdin_hash || ct_hash)
  const pre = Buffer.from("ATTEST|RAT|v1|", "utf8");
  const msg = Buffer.concat([
    pre,
    hexToBuf(ts_hash_hex, "ts_hash_hex"),
    hexToBuf(stdin_sha256_hex, "stdin_sha256_hex"),
    hexToBuf(dem_ct_sha256_hex, "dem_ct_sha256_hex"),
  ]);
  return dsha256(msg); // 32 bytes
}

function opReturnPayloadHex(attestHash32) {
  // 36 bytes total: ASCII "RAT0" + 32-byte attestation hash
  const prefix = Buffer.from("RAT0", "ascii");
  const payload = Buffer.concat([prefix, attestHash32]);
  return payload.toString("hex");
}

function opReturnScriptPubKeyHex(payloadHex) {
  const payload = hexToBuf(payloadHex, "op_return_payload");
  const len = payload.length;
  if (len > 80) throw new Error(`OP_RETURN payload too large: ${len} bytes (max 80).`);
  // OP_RETURN (0x6a) + PUSHDATA (len<=75 -> 1-byte len, else PUSHDATA1)
  if (len <= 75) {
    return Buffer.concat([Buffer.from([0x6a, len]), payload]).toString("hex");
  }
  return Buffer.concat([Buffer.from([0x6a, 0x4c, len]), payload]).toString("hex");
}

/* ============================================================
   SPHINCS signing hook (dynamic import)
============================================================ */
async function maybeSphincsSign(messageBytes) {
  if (!ARGS.sphincsModule || !ARGS.sphincsSkHex) {
    return { signature_b64u: null, signer: null, note: "No SPHINCS module/key provided; signature omitted." };
  }

  let mod;
  try {
    mod = await import(ARGS.sphincsModule);
  } catch (e) {
    return { signature_b64u: null, signer: null, note: `Failed to import SPHINCS module "${ARGS.sphincsModule}".` };
  }

  // Expected minimal interface (you can adapt to your chosen library):
  //   mod.sign(skBytes, msgBytes) -> Uint8Array
  // Optionally: mod.SIGN_BYTES / mod.PUBLICKEY_BYTES, etc.
  if (!mod || typeof mod.sign !== "function") {
    return { signature_b64u: null, signer: null, note: "SPHINCS module lacks sign(sk,msg) function." };
  }

  const sk = hexToBuf(ARGS.sphincsSkHex, "sphincs_sk_hex");
  const ctx = Buffer.from(String(ARGS.sphincsCtx || ""), "utf8");

  // Context-bound message: ctx || 0x00 || message
  const toSign = Buffer.concat([ctx, Buffer.from([0x00]), messageBytes]);

  let sig;
  try {
    const out = mod.sign(sk, toSign);
    sig = Buffer.from(out);
  } catch (e) {
    return { signature_b64u: null, signer: null, note: "SPHINCS signing threw error." };
  }

  return {
    signature_b64u: b64u(sig),
    signer: { module: ARGS.sphincsModule, ctx: ARGS.sphincsCtx },
    note: null
  };
}

/* ============================================================
   MAIN
============================================================ */
(async () => {
  try {
    const ts = generateTimestamp();

    const { buf: inputBuf, sha256hex: stdin_sha256_hex } =
      await readStdinValidated({ maxBytes: ARGS.maxBytes, allowEmpty: ARGS.allowEmpty });

    const plaintext =
      inputBuf.length ? inputBuf.toString("utf8")
      : (process.stdin.isTTY ? TEST_DATA : inputBuf.toString("utf8"));

    const { pk, sk } = kemKeygen();
    const { ctKem_b64u, ss } = kemEncaps(pk);
    const dem = demEncrypt(ss, plaintext);

    const ss2 = kemDecaps(sk, ctKem_b64u);
    const decrypted = demDecrypt(ss2, dem);
    const verified = (decrypted === plaintext);

    if (!verified) {
      throw new Error("Decryption failed (round-trip verification mismatch).");
    }

    // Hashes for attestation
    const dem_ct_sha256_hex = sha256Hex(dem.ct_raw);

    // Merkle-safe attestation hash (32 bytes)
    const attestHash = domainSeparatedAttestHash({
      ts_hash_hex: ts.ts_hash_hex,
      stdin_sha256_hex,
      dem_ct_sha256_hex
    });
    const attestation_hash_hex = attestHash.toString("hex");

    // Signature message bytes = timestamp_canonical || ciphertext_sha256 || stdin_sha256
    const sigMsg = Buffer.concat([
      Buffer.from(ts.canonical, "utf8"),
      Buffer.from("|", "utf8"),
      hexToBuf(dem_ct_sha256_hex, "dem_ct_sha256_hex"),
      hexToBuf(stdin_sha256_hex, "stdin_sha256_hex"),
    ]);

    const sig = await maybeSphincsSign(sigMsg);

    // OP_RETURN
    const op_return_payload_hex = opReturnPayloadHex(attestHash);
    const op_return_scriptpubkey_hex = opReturnScriptPubKeyHex(op_return_payload_hex);

    // Single attestation JSON record
    const record = {
      schema: "rat_attestation/v1",
      created_at: ts.iso,
      timestamp: {
        iso: ts.iso,
        unix: ts.unix,
        millis: ts.millis,
        canonical: ts.canonical,
        ts_hash_dsha256_hex: ts.ts_hash_hex
      },
      stdin: {
        bytes: inputBuf.length,
        sha256_hex: stdin_sha256_hex
      },
      kem_dem: {
        curve: "secp256k1",
        dem: "chacha20-poly1305",
        static_pk_b64u: b64u(pk),
        kem_ct_b64u: ctKem_b64u,
        nonce_b64u: dem.nonce_b64u,
        ct_b64u: dem.ct_b64u,
        tag_b64u: dem.tag_b64u,
        dem_ct_sha256_hex
      },
      binding: {
        // Merkle-safe domain-separated attestation hash
        attestation_hash_dsha256_hex: attestation_hash_hex,
        signed_message_format: "timestamp_canonical || '|' || dem_ct_sha256_rawbytes || stdin_sha256_rawbytes"
      },
      signature: {
        scheme: "SPHINCS+",
        signature_b64u: sig.signature_b64u,
        signer: sig.signer,
        note: sig.note
      },
      bitcoin: {
        op_return_payload_hex,         // 36 bytes: "RAT0" + attestation_hash
        op_return_scriptpubkey_hex     // 6a + pushdata + payload
      }
    };

    if (ARGS.jsonOnly) {
      process.stdout.write(JSON.stringify(record, null, 2) + "\n");
      return;
    }

    // Optional text output (if --text used)
    console.log(JSON.stringify(record, null, 2));
    console.log("\nDecrypted plaintext:\n");
    console.log(decrypted);

  } catch (e) {
    console.error("FATAL:", e && e.message ? e.message : String(e));
    process.exit(1);
  }
})();
